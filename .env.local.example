# Supabase 설정 (선택 사항 - 미설정 시 data.json fallback)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (관리자 데이터 업로드용 - 절대 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# 관리자 설정
ADMIN_PASSWORD=your-admin-password-here
ADMIN_SESSION_SECRET=random-secret-string-here

# Google AdSense 설정
# AdSense 승인 후 발급받은 게시자 ID를 입력하세요 (예: ca-pub-1234567890123456)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# 각 광고 위치별 슬롯 ID (AdSense에서 광고 단위 생성 후 발급)
NEXT_PUBLIC_AD_SLOT_SIDEBAR_LEFT=YOUR_LEFT_SIDEBAR_SLOT_ID
NEXT_PUBLIC_AD_SLOT_SIDEBAR_RIGHT=YOUR_RIGHT_SIDEBAR_SLOT_ID
NEXT_PUBLIC_AD_SLOT_IN_ARTICLE=YOUR_IN_ARTICLE_SLOT_ID
NEXT_PUBLIC_AD_SLOT_ANCHOR=YOUR_ANCHOR_SLOT_ID
NEXT_PUBLIC_AD_SLOT_IN_FEED=YOUR_IN_FEED_SLOT_ID
